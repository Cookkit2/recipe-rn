# Production Environment Variables

NODE_ENV=production
APP_NAME=cookkit
API_URL=https://api.cookkit.app

# Supabase Production
NEXT_PUBLIC_SUPABASE_URL=https://production.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=production_anon_key_placeholder
SUPABASE_SERVICE_ROLE_KEY=production_service_role_key_placeholder

# Sentry Production
NEXT_PUBLIC_SENTRY_DSN=https://production@sentry.io/12345
SENTRY_ENVIRONMENT=production

# Expo Production
EXPO_PROJECT_ID=production-project-id

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true
ENABLE_PERFORMANCE_MONITORING=true

# Logging
LOG_LEVEL=error

# Rate Limiting (Production)
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=900000

# Security (Production)
SESSION_TIMEOUT=3600000
