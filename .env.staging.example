# Staging Environment Variables

NODE_ENV=staging
APP_NAME=cookkit-staging
API_URL=https://staging-api.cookkit.app

# Supabase Staging
NEXT_PUBLIC_SUPABASE_URL=https://staging.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=staging_anon_key_placeholder
SUPABASE_SERVICE_ROLE_KEY=staging_service_role_key_placeholder

# Sentry Staging
NEXT_PUBLIC_SENTRY_DSN=https://staging@sentry.io/12345
SENTRY_ENVIRONMENT=staging

# Expo Staging
EXPO_PROJECT_ID=staging-project-id

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true
ENABLE_PERFORMANCE_MONITORING=true

# Logging
LOG_LEVEL=debug
