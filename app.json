{
  "expo": {
    "name": "recipe",
    "slug": "recipe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "recipe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.recipe.recipe"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.recipe.recipe",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Urbanist-Thin.ttf",
            "./assets/fonts/Urbanist-ExtraLight.ttf",
            "./assets/fonts/Urbanist-Light.ttf",
            "./assets/fonts/Urbanist-Regular.ttf",
            "./assets/fonts/Urbanist-Medium.ttf",
            "./assets/fonts/Urbanist-SemiBold.ttf",
            "./assets/fonts/Urbanist-Bold.ttf",
            "./assets/fonts/Urbanist-ExtraBold.ttf",
            "./assets/fonts/Urbanist-Black.ttf",
            "./assets/fonts/Urbanist-ThinItalic.ttf",
            "./assets/fonts/Urbanist-ExtraLightItalic.ttf",
            "./assets/fonts/Urbanist-LightItalic.ttf",
            "./assets/fonts/Urbanist-Italic.ttf",
            "./assets/fonts/Urbanist-MediumItalic.ttf",
            "./assets/fonts/Urbanist-SemiBoldItalic.ttf",
            "./assets/fonts/Urbanist-BoldItalic.ttf",
            "./assets/fonts/Urbanist-ExtraBoldItalic.ttf",
            "./assets/fonts/Urbanist-BlackItalic.ttf"
          ]
        }
      ],
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Recipe to access your camera",
          "microphonePermission": "Allow Recipe to access your microphone",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f5078ee-39ba-406b-9c9f-5cbd12094d9f"
      }
    }
  }
}
