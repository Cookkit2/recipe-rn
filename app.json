{
  "expo": {
    "name": "Cookkit",
    "slug": "cookkit",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cookkit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.cookkit.cookkit",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera to capture ingredients",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone",
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photos of ingredients",
        "NSLocationWhenInUseUsageDescription": "Allow $(PRODUCT_NAME) to access your location to locate your nearby grocery stores"
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.cookkit.cookkit",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "linking": {
      "prefixes": [
        "recipe-app://"
      ],
      "config": {
        "screens": {
          "auth": {
            "screens": {
              "callback": "auth/callback",
              "reset-password": "auth/reset-password"
            }
          }
        }
      }
    },
    "plugins": [
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Bowlby One",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/BowlbyOne-Regular.ttf",
                    "weight": 400
                  }
                ]
              },
              {
                "fontFamily": "Urbanist",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Urbanist-Thin.ttf",
                    "weight": 100
                  },
                  {
                    "path": "./assets/fonts/Urbanist-ExtraLight.ttf",
                    "weight": 200
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Light.ttf",
                    "weight": 300
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Urbanist-SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Urbanist-ExtraBold.ttf",
                    "weight": 800
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Black.ttf",
                    "weight": 900
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/BowlbyOne-Regular.ttf",
              "./assets/fonts/Urbanist-Thin.ttf",
              "./assets/fonts/Urbanist-ExtraLight.ttf",
              "./assets/fonts/Urbanist-Light.ttf",
              "./assets/fonts/Urbanist-Regular.ttf",
              "./assets/fonts/Urbanist-Medium.ttf",
              "./assets/fonts/Urbanist-SemiBold.ttf",
              "./assets/fonts/Urbanist-Bold.ttf",
              "./assets/fonts/Urbanist-ExtraBold.ttf",
              "./assets/fonts/Urbanist-Black.ttf"
            ]
          }
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableCoreMLDelegate": true
        }
      ],
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermission": "Allow Cookkit to use your camera to take photos of ingredients"
        }
      ],
      "expo-web-browser",
      "expo-video",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "cookkit-d6"
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true,
      "typedRoutes": true,
      "buildCacheProvider": {
        "plugin": "expo-build-disk-cache"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "191bf781-c649-4520-84d0-461f5b5a8427"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/191bf781-c649-4520-84d0-461f5b5a8427"
    }
  }
}
