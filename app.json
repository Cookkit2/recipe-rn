{
  "expo": {
    "name": "recipe",
    "slug": "recipe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "recipe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.recipe.recipe"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.recipe.recipe"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/mullish.ttf"],
          "android": {
            "fonts": [
              {
                "fontFamily": "Mullish",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/mullish.ttf",
                    "weight": 800
                  }
                ]
              }
            ]
          }
        }
      ],
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Recipe to access your camera",
          "microphonePermission": "Allow Recipe to access your microphone",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
