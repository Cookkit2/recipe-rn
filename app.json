{
  "expo": {
    "name": "Cookkit",
    "slug": "cookkit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cookkit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.cookkit.cookkit",
      "appStoreId": "0000000000"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.cookkit.cookkit",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "parentTheme": "Default"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Bowlby One",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/BowlbyOne-Regular.ttf",
                    "weight": 400
                  }
                ]
              },
              {
                "fontFamily": "Urbanist",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Urbanist-Thin.ttf",
                    "weight": 100
                  },
                  {
                    "path": "./assets/fonts/Urbanist-ExtraLight.ttf",
                    "weight": 200
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Light.ttf",
                    "weight": 300
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Urbanist-SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Urbanist-ExtraBold.ttf",
                    "weight": 800
                  },
                  {
                    "path": "./assets/fonts/Urbanist-Black.ttf",
                    "weight": 900
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/BowlbyOne-Regular.ttf",
              "./assets/fonts/Urbanist-Thin.ttf",
              "./assets/fonts/Urbanist-ExtraLight.ttf",
              "./assets/fonts/Urbanist-Light.ttf",
              "./assets/fonts/Urbanist-Regular.ttf",
              "./assets/fonts/Urbanist-Medium.ttf",
              "./assets/fonts/Urbanist-SemiBold.ttf",
              "./assets/fonts/Urbanist-Bold.ttf",
              "./assets/fonts/Urbanist-ExtraBold.ttf",
              "./assets/fonts/Urbanist-Black.ttf"
            ]
          }
        }
      ],
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Cookkit to access your camera",
          "microphonePermission": "Allow Cookkit to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "191bf781-c649-4520-84d0-461f5b5a8427"
      }
    }
  }
}
