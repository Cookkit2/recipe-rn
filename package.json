{
  "name": "my-app",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start -c",
    "start:web": "expo start -c --web",
    "start:android": "expo start -c --android",
    "android": "expo run android",
    "ios": "expo run ios",
    "web": "expo start -c --web",
    "eas:build:ios": "eas build --platform ios --profile production",
    "clean": "rm -rf .expo node_modules",
    "postinstall": "patch-package && npx tailwindcss -i ./global.css -o ./node_modules/.cache/nativewind/global.css --config ./tailwind.config.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:check": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:dev": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 100",
    "test": "jest",
    "test:storage": "jest __tests__/storage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:storage-coverage": "jest __tests__/storage --coverage",
    "css-to-json": "bun scripts/css-to-json-converter-advanced.js --merge --backup global.css constants/colors.json",
