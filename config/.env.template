# Environment Configuration Template
# Copy this file to .env.local and fill in your values

# API Endpoints
REACT_APP_API_URL=https://api.recipe-n.com/v1
REACT_APP_GRAPHQL_URL=https://api.recipe-n.com/graphql
REACT_APP_WS_URL=wss://api.recipe-n.com/graphql

# Authentication
REACT_APP_JWT_EXPIRATION_MINUTES=15
REACT_APP_REFRESH_TOKEN_EXPIRY_DAYS=7

# File Upload
REACT_APP_UPLOAD_URL=https://api.recipe-n.com/upload
REACT_APP_MAX_IMAGE_SIZE_MB=5
REACT_APP_COMPRESSION_QUALITY=0.8

# Features
REACT_APP_ENABLE_OFFLINE_MODE=true
REACT_APP_ENABLE_PUSH_NOTIFICATIONS=true
REACT_APP_ENABLE_ANALYTICS=true

# Analytics
REACT_APP_ANALYTICS_ID=your-analytics-id-here

# Environment
REACT_APP_ENV=development
REACT_APP_DEBUG=true

# Cloud Services (Optional - for future cloud sync)
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key
REACT_APP_FIREBASE_PROJECT_ID=your-firebase-project-id
REACT_APP_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
REACT_APP_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
