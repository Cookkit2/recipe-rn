# Environment Variables Template
# Copy this file to .env.local and fill in the actual values
# NEVER commit .env.local or any .env files with real credentials

# Application
NODE_ENV=development
APP_NAME=cookkit
APP_VERSION=1.1.0
API_URL=http://localhost:3000

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# OAuth Providers
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
APPLE_OAUTH_CLIENT_ID=your_apple_oauth_client_id
APPLE_OAUTH_TEAM_ID=your_apple_team_id
APPLE_OAUTH_KEY_ID=your_apple_key_id
APPLE_OAUTH_PRIVATE_KEY=your_apple_private_key

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# Expo / EAS
EXPO_PROJECT_ID=your_expo_project_id
EXPO_ACCOUNT_OWNER=your_expo_account_owner

# API Keys (if using external services)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Storage
AWS_S3_BUCKET=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Database (if needed)
DATABASE_URL=your_database_url
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis (if using caching)
REDIS_URL=your_redis_url
REDIS_PASSWORD=your_redis_password

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true
ENABLE_PERFORMANCE_MONITORING=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# CORS
CORS_ORIGIN=http://localhost:8081

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
ENCRYPTION_KEY=your_encryption_key_32_chars_long
SESSION_SECRET=your_session_secret_min_32_chars
CSRF_SECRET=your_csrf_secret_min_32_chars

# Email (if using email services)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@cookkit.app

# Push Notifications
FIREBASE_SERVER_KEY=your_firebase_server_key
FIREBASE_SENDER_ID=your_firebase_sender_id

# Monitoring & Observability
GRAFANA_CLOUD_URL=your_grafana_cloud_url
GRAFANA_API_KEY=your_grafana_api_key
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key

# Deployment
DEPLOY_ENVIRONMENT=development
DEPLOY_VERSION=1.0.0
DEPLOY_TIMESTAMP=2024-01-01T00:00:00Z
