# Copy to .env and fill in values. Never commit .env.
# See README and docs/DEPLOYMENT.md for setup.

# Supabase (required for auth and cloud sync)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Malaysia grocery outbound (optional)
# Set to false to hide 99 Speedmart / Jaya Grocer shortcuts everywhere.
# EXPO_PUBLIC_MY_SHOP_ENABLED=false
# Grab storefront URL for Jaya Grocer (GrabMart / deep link when you have it)
# EXPO_PUBLIC_GRAB_JAYA_GROCER_URL=https://food.grab.com/my/en

# Sentry (optional; leave unset to disable error reporting)
EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_SENTRY_SEND_PII=false

# MMKV encrypted storage (optional; omit to use non-encrypted storage for dev)
# EXPO_PUBLIC_MMKV_ENCRYPTION_KEY=your-32-char-secret-key-here

# RevenueCat (required for in-app purchases)
EXPO_PUBLIC_REVENUECAT_PROJECT_APPLE_API_KEY=
EXPO_PUBLIC_REVENUECAT_PROJECT_GOOGLE_API_KEY=

# EAS / CI only (not used at app runtime)
# SENTRY_AUTH_TOKEN=  # For uploading source maps in EAS Build
